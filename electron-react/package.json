{
  "name": "openassist-electron-react",
  "productName": "Open Assist",
  "version": "0.1.0",
  "private": true,
  "description": "React and Electron shell for Open Assist.",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 5187",
    "dev:electron": "wait-on tcp:5187 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5187 electron .",
    "build": "tsc -p tsconfig.electron.json && vite build",
    "package:mac": "npm run build && electron-packager . \"Open Assist\" --platform=darwin --arch=arm64 --out=out --overwrite --app-bundle-id=com.developingadventures.OpenAssistElectronReact --app-version=0.1.0 --build-version=1 --icon=icon.icns --no-asar --ignore='^/(out|out-unpacked|verification|\\.vite|dist-renderer/assets/.*\\.map)$'",
    "release:mac": "bash scripts/build-mac-release.sh",
    "verify:running": "node scripts/verify-running-electron.mjs",
    "verify:packaged": "npm run package:mac && node scripts/verify-packaged-electron.mjs && node scripts/verify-insertion-smoke.mjs",
    "verify:git-checkpoints": "npm run build && node scripts/verify-git-checkpoint-service.mjs",
    "verify:realtime-protocol": "node scripts/verify-codex-realtime-protocol.mjs",
    "verify:insertion": "node scripts/verify-insertion-smoke.mjs",
    "capture:native": "node scripts/capture-native-reference.mjs",
    "capture:running": "node scripts/capture-running-window.mjs",
    "capture:packaged": "node scripts/capture-packaged-views.mjs",
    "preview": "vite preview --host 127.0.0.1 --port 5187",
    "start": "npm run build && electron ."
  },
  "keywords": [
    "openassist",
    "electron",
    "react"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@tiptap/extension-image": "^3.23.4",
    "@tiptap/extension-placeholder": "^3.23.4",
    "@tiptap/extension-table": "^3.23.4",
    "@tiptap/extension-task-item": "^3.23.4",
    "@tiptap/extension-task-list": "^3.23.4",
    "@tiptap/markdown": "^3.23.4",
    "@tiptap/pm": "^3.23.4",
    "@tiptap/react": "^3.23.4",
    "@tiptap/starter-kit": "^3.23.4",
    "@vitejs/plugin-react": "^5.1.2",
    "framer-motion": "^12.23.24",
    "kokoro-js": "^1.2.1",
    "lucide-react": "^0.561.0",
    "mermaid": "^11.15.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^15.6.6",
    "remark-gfm": "^4.0.1",
    "vite": "^7.3.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "@types/node": "^25.0.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.3"
  }
}
